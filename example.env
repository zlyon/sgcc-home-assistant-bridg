# SGCC Home Assistant Bridge 示例配置
# 使用方法：复制为 .env 后按需填写；不要把真实账号、密码、Token 提交到仓库。

# ===== 国网账号 =====
# 国家电网 95598 登录手机号/账号
PHONE_NUMBER="your-phone-number"
# 国家电网 95598 登录密码
PASSWORD="your-password"
# 忽略指定户号，多个用英文逗号分隔；留空表示不忽略
IGNORE_USER_ID=""

# ===== Home Assistant =====
# Home Assistant 地址；REST 发布模式需要
HASS_URL="http://homeassistant.local:8123"
# Home Assistant 长期访问令牌；REST 发布模式需要
HASS_TOKEN="your-home-assistant-long-lived-token"

# ===== LLM 验证码 =====
# OpenAI 兼容多模态接口 Key，用于腾讯点选验证码坐标识别。
# 火山方舟/豆包用户也可以填 ARK_API_KEY；LLM_API_KEY 优先级更高。
LLM_API_KEY="your-llm-api-key"
# OpenAI 兼容接口 Base URL；火山方舟默认如下。
LLM_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
# 多模态模型名称。火山方舟推荐填写你创建的接入点 ID（ep- 开头），也可使用兼容模型名。
LLM_MODEL="doubao-seed-2-0-pro-260215"
# 上游/火山方舟兼容别名，可二选一使用；留空时忽略。
# ARK_API_KEY="ark-xxxxxxxx"
# ARK_MODEL="ep-20260601092754-xxxxx"
# 密码/点选验证码登录失败后的兜底方式：qrcode 表示二维码人工扫码
LOGIN_FALLBACK="qrcode"

# ===== 发布（MQTT + REST） =====
# 发布方式：mqtt / rest / both；推荐 mqtt，只生成 MQTT Discovery 设备实体
# 如需兼容旧仪表盘/自动化，可改为 both 同时发布旧 REST 实体
PUBLISHER="mqtt"
# Home Assistant 使用的 MQTT Broker（如 Mosquitto）地址；PUBLISHER 为 mqtt/both 时使用
MQTT_HOST="127.0.0.1"
# MQTT Broker 端口
MQTT_PORT=1883
# MQTT 用户名；无认证可留空
MQTT_USERNAME=""
# MQTT 密码；无认证可留空
MQTT_PASSWORD=""
# Home Assistant MQTT Discovery 前缀，默认 homeassistant
MQTT_DISCOVERY_PREFIX="homeassistant"

# ===== 抓取调参 =====
# 每日任务开始时间，24 小时制 HH:MM
JOB_START_TIME="07:00"
# 每天真实登录抓取次数；无人值守建议 1，设为 2 会恢复早晚两次
SGCC_DAILY_RUNS=1
# 登录/抓取重试次数上限；风控/验证码通过后仍失败会熔断，不参与立即重试
RETRY_TIMES_LIMIT=5
# 风控类登录失败后的无人值守冷却分钟数
RISK_COOLDOWN_MINUTES=60
# 是否启用登录风控冷却；建议保持 true
SGCC_LOGIN_COOLDOWN_ENABLED=true
# 无人值守定时任务是否允许二维码兜底；默认 false，避免无人扫码时长时间挂起
SGCC_QRCODE_FALLBACK_UNATTENDED=false
# 页面点击/加载后的基础等待秒数，网络或设备慢时可调大
RETRY_WAIT_TIME_OFFSET_UNIT=10
# Selenium 显式等待相关页面元素的秒数
DRIVER_IMPLICITY_WAIT_TIME=60
# 页面加载超时秒数
PAGE_LOAD_TIMEOUT=45
# Path B 抓取等待 Vue/Vuex/组件数据稳定的秒数
SCRAPER_SETTLE_SECONDS=3.0
# 两次状态重发布/补抓之间的间隔分钟数
REPUBLISH_INTERVAL_MINUTES=15
# ===== 浏览器模式 =====
# local: 原方案，app 容器内 Debian Chromium + Xvfb + ChromeDriver。
# browser-service: 推荐给 NAS/x86 小主机，官方 Google Chrome sidecar 按需启动，Selenium 通过 CDP attach，用完关闭 Chrome。
# host-cdp/cdp: 高级模式，连接外部已启动的 Chrome CDP。
SGCC_BROWSER_MODE="browser-service"
# local 模式使用的 Chromium 用户数据目录。
SGCC_BROWSER_PROFILE="/data/chrome-profile"
# browser-service / host-cdp 使用的 CDP 地址；默认 sidecar 监听宿主机 loopback 19222。
SGCC_CDP_ADDRESS="127.0.0.1:19222"
# browser-service 管理 API；app 通过它启动/停止 sidecar 内的 Google Chrome。
SGCC_BROWSER_SERVICE_URL="http://127.0.0.1:39222"
SGCC_BROWSER_SERVICE_STOP_ON_RELEASE="true"
# browser-service sidecar profile 挂载路径，Chrome 关闭后仍保留 profile，但国网登录态不保证可复用。
SGCC_BROWSER_SERVICE_PROFILE_HOST="/data/sgcc-browser-profile"
SGCC_BROWSER_SERVICE_PROFILE="/data/sgcc-browser-profile"
