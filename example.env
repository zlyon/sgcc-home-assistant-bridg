# SGCC Home Assistant Bridge 示例配置
# 使用方法：复制为 .env 后按需填写；不要把真实账号、密码、Token 提交到仓库。

# ===== 国网账号 =====
# 国家电网 95598 登录手机号/账号
PHONE_NUMBER="your-phone-number"
# 国家电网 95598 登录密码
PASSWORD="your-password"
# 忽略指定户号，多个用英文逗号分隔；留空表示不忽略
IGNORE_USER_ID=""

# ===== Home Assistant =====
# Home Assistant 地址；REST 发布模式需要
HASS_URL="http://homeassistant.local:8123"
# Home Assistant 长期访问令牌；REST 发布模式需要
HASS_TOKEN="your-home-assistant-long-lived-token"

# ===== LLM 验证码 =====
# OpenAI 兼容多模态接口 Key，用于腾讯点选验证码坐标识别。
# 火山方舟/豆包用户也可以填 ARK_API_KEY；LLM_API_KEY 优先级更高。
LLM_API_KEY="your-llm-api-key"
# OpenAI 兼容接口 Base URL；火山方舟默认如下。
LLM_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
# 多模态模型名称。火山方舟推荐填写你创建的接入点 ID（ep- 开头），也可使用兼容模型名。
LLM_MODEL="doubao-seed-2-0-pro-260215"
# 上游/火山方舟兼容别名，可二选一使用；留空时忽略。
# ARK_API_KEY="ark-xxxxxxxx"
# ARK_MODEL="ep-20260601092754-xxxxx"
# 密码/点选验证码失败后的兜底顺序：phone-code,qrcode 表示先短信验证码、再二维码
# 默认保留 qrcode；定时任务是否执行兜底由 SGCC_LOGIN_FALLBACK_UNATTENDED 控制
LOGIN_FALLBACK="qrcode"
SGCC_LOGIN_FALLBACK_METHODS="qrcode"

# ===== 发布（MQTT + REST） =====
# 发布方式：mqtt / rest / both；推荐 mqtt，只生成 MQTT Discovery 设备实体
# 需要同时发布 MQTT Discovery 与 HA REST state 时可改为 both
PUBLISHER="mqtt"
# Home Assistant 使用的 MQTT Broker（如 Mosquitto）地址；PUBLISHER 为 mqtt/both 时使用
MQTT_HOST="127.0.0.1"
# MQTT Broker 端口
MQTT_PORT=1883
# MQTT 用户名；无认证可留空
MQTT_USERNAME=""
# MQTT 密码；无认证可留空
MQTT_PASSWORD=""
# Home Assistant MQTT Discovery 前缀，默认 homeassistant
MQTT_DISCOVERY_PREFIX="homeassistant"

# ===== 抓取调参 =====
# 每日任务基准时间，24 小时制 HH:MM
JOB_START_TIME="07:00"
# 每日任务随机偏移窗口（分钟），范围 0..180；默认 10 表示每天抽取 ±10 分钟，0 关闭
# 持续运行期间每天重新抽取；每天两次任务共用当天偏移并保持 12 小时间隔
SGCC_DAILY_JITTER_MINUTES=10
# 每天真实登录抓取次数；无人值守建议 1，设为 2 会恢复早晚两次并共用当天偏移
SGCC_DAILY_RUNS=1
# 登录/抓取重试次数上限；风控/验证码通过后仍失败会熔断，不参与立即重试
RETRY_TIMES_LIMIT=5
# 风控类登录失败后的无人值守冷却分钟数
RISK_COOLDOWN_MINUTES=60
# 是否启用登录风控冷却；建议保持 true
SGCC_LOGIN_COOLDOWN_ENABLED=true
# 是否允许在 RK001 后尝试已配置的人工兜底；默认 false，保持直接冷却
# 仅在已确认密码登录持续 RK001、短信登录仍可用时谨慎开启；这不是风控重试或绕过开关
SGCC_RISK_FALLBACK_OVERRIDE=false
# 无人值守定时任务是否允许短信/二维码交互兜底；默认 false，避免无人响应时挂起
SGCC_LOGIN_FALLBACK_UNATTENDED=false
# 旧二维码专用开关保持兼容；新配置优先使用上面的统一开关
SGCC_QRCODE_FALLBACK_UNATTENDED=false
# 登录交互提供方：auto / telegram / url / both / none
# auto 会优先启用已完整配置的 Telegram，同时兼容 PUSH_QRCODE_URL
SGCC_LOGIN_INTERACTION_PROVIDER=auto
# Telegram Bot 凭证与唯一允许交互的 Chat ID；短信验证码必须回复 Bot 当前提示消息
SGCC_TELEGRAM_BOT_TOKEN=""
SGCC_TELEGRAM_CHAT_ID=""
SGCC_TELEGRAM_API_BASE_URL="https://api.telegram.org"
# 等待短信验证码回复的秒数，范围 30..600
SGCC_SMS_CODE_TIMEOUT_SECONDS=180
# 页面点击/加载后的基础等待秒数，网络或设备慢时可调大
RETRY_WAIT_TIME_OFFSET_UNIT=10
# Selenium 显式等待相关页面元素的秒数
DRIVER_IMPLICITY_WAIT_TIME=60
# 页面加载超时秒数
PAGE_LOAD_TIMEOUT=45
# Path B 抓取等待 Vue/Vuex/组件数据稳定的秒数
SCRAPER_SETTLE_SECONDS=3.0
# 完整 Debug 取证；未知省份/字段只需开启一次，输出 Network/Vuex/Component/DOM、
# shape、候选和 parser decision 的脱敏 bundle，不改变实际发布结果；
# Debug 目录/文件固定使用 0700/0600 权限
SGCC_DEBUG=false
SGCC_DEBUG_DIR=/data/debug
# 旧 /data/errors 只保存脱敏 metadata；确需页面截图时显式开启，截图需人工检查后再外发
SGCC_ERROR_SCREENSHOT=false
SGCC_ERROR_MAX_CAPTURES=10
# 旧诊断开关保持兼容，等价于 SGCC_DEBUG=true
SGCC_DIAG=false
SGCC_DIAG_DIR=/data/diag
# 登录方式；phone-code 仅用于交互式手工短信验证码登录
SGCC_LOGIN_METHOD=password
# 两次状态重发布/补抓之间的间隔分钟数
REPUBLISH_INTERVAL_MINUTES=15
# 通知服务 HTTP 超时秒数；通知失败与国网抓取、Store、HA/MQTT 发布隔离
PUSH_TIMEOUT=10
# v2 实体使用“末四位 + 稳定摘要”避免多户号碰撞；确认仪表盘已迁移后可执行一次旧 REST 实体清理
SGCC_CLEANUP_LEGACY_ENTITY_IDS=false
# ===== 浏览器模式 =====
# local: 原方案，app 容器内 Debian Chromium + Xvfb + ChromeDriver。
# browser-service: 推荐；Docker Compose 使用官方 Google Chrome sidecar，Home Assistant Add-on 使用单容器内嵌 browser manager，Chrome 按需启动，Selenium 通过 CDP attach，用完关闭 Chrome。
# host-cdp/cdp: 高级模式，连接外部已启动的 Chrome CDP。
SGCC_BROWSER_MODE="browser-service"
# local 模式使用的 Chromium 用户数据目录。
SGCC_BROWSER_PROFILE="/data/chrome-profile"
# browser-service / host-cdp 使用的 CDP 地址；Compose 默认 sidecar 监听宿主机 loopback 19222，Add-on 默认同容器 127.0.0.1:19222。
SGCC_CDP_ADDRESS="127.0.0.1:19222"
# browser-service 管理 API；Compose 指向 sidecar，Add-on 指向同容器内嵌 browser manager。
SGCC_BROWSER_SERVICE_URL="http://127.0.0.1:39222"
SGCC_BROWSER_SERVICE_STOP_ON_RELEASE="true"
# 可选高级开关：仅当 app/browser 使用自定义 Docker network、且需要通过服务名访问 browser 容器 CDP 时启用。
# 新版 Chrome 可能强制 CDP 只监听 127.0.0.1；启用后 browser-service 会用内置代理把 SGCC_BROWSER_CDP_PORT 转发到内部端口。
SGCC_BROWSER_CDP_FORWARD_ENABLED="false"
SGCC_BROWSER_CDP_INTERNAL_PORT="19223"
# browser-service profile 路径，Chrome 关闭后仍保留 profile，但国网登录态不保证可复用。
# Compose 使用 SGCC_BROWSER_SERVICE_PROFILE_HOST 做宿主机挂载；Add-on 忽略 HOST 变量，只使用容器内 SGCC_BROWSER_SERVICE_PROFILE。
SGCC_BROWSER_SERVICE_PROFILE_HOST="/data/sgcc-browser-profile"
SGCC_BROWSER_SERVICE_PROFILE="/data/sgcc-browser-profile"
